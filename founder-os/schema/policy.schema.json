{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://founder-os/schema/policy.schema.json",
  "title": "founder-os policy.json",
  "description": "Schema for policy.json, the rule set consumed by bin/policy-check.js and adapters/opencode/plugin.ts. Used by both the hand-rolled validator (bin/validate-policy-schema.js) and the ajv-based benchmark competitor -- see founder-os/DECISIONS.md for which one is actually wired into the loaders.",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": true,
  "properties": {
    "_comment": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["id", "category", "pattern", "action", "message"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "enum": ["bash", "any"]
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "flags": {
          "type": "string",
          "pattern": "^[gimsuy]*$"
        },
        "action": {
          "type": "string",
          "enum": ["block", "confirm"]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
