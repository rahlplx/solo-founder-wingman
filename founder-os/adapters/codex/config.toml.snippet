# founder-os recommended Codex CLI configuration.
#
# Codex has no code-level hook mechanism (unlike Claude Code's hooks.json or
# OpenCode's tool.execute.before) -- this is policy/sandbox-level protection
# only, per OpenAI's own documented guidance. It's a real, human-in-the-loop
# gate (nothing runs outside the sandbox without your approval), just a
# weaker guarantee than code-level interception. This gap is documented for
# the founder in the generated AGENTS.md "Known Limitations by Platform"
# section -- it is not hidden.
#
# Merge this into ~/.codex/config.toml or a project-scoped .codex/config.toml.

approval_policy = "on-request"
sandbox_mode = "workspace-write"

# Do NOT set approval_policy = "never" combined with
# sandbox_mode = "danger-full-access" -- OpenAI's own docs explicitly warn
# against this combination.

# --- MCP servers -----------------------------------------------------------
# Local/stdio servers are well-documented for Codex's config.toml. Several of
# our integrations (Supabase, Stripe, Vercel, Sentry) now default to
# vendor-hosted remote servers with OAuth -- verify current Codex support for
# remote/URL-based MCP servers before assuming the syntax below; only the
# local stdio pattern is confirmed as of this writing.
#
# Versions below are pinned to what was current on the npm/container
# registries as of this writing (July 2026) -- update deliberately, not via
# an unpinned @latest, per the supply-chain finding from the external audit
# round that flagged this file.

[mcp_servers.playwright]
command = "npx"
args = ["-y", "@playwright/mcp@0.0.77"]

# @modelcontextprotocol/server-github is DEPRECATED on the npm registry
# ("Package no longer supported") -- confirmed by checking `npm view
# @modelcontextprotocol/server-github deprecated` directly, not assumed.
# The real official GitHub MCP server (github/github-mcp-server) ships as a
# Docker image; requires Docker installed, which is a real dependency this
# adds for Codex users specifically (Claude Code/OpenCode use the simpler
# remote HTTP endpoint instead -- see .mcp.json -- since Codex's config.toml
# only confirms local/stdio server support).
[mcp_servers.github]
command = "docker"
args = ["run", "-i", "--rm", "-e", "GITHUB_PERSONAL_ACCESS_TOKEN", "ghcr.io/github/github-mcp-server"]
[mcp_servers.github.env]
GITHUB_PERSONAL_ACCESS_TOKEN = "${GITHUB_TOKEN}"

# Supabase, Stripe, Vercel, Sentry, PostHog: see references/mcp-servers.md
# for their current (mostly remote+OAuth) connection details. Add them here
# once remote MCP server support in Codex's config.toml is confirmed.
