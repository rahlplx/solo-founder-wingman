{
  "name": "founder-os",
  "version": "0.3.0",
  "private": true,
  "description": "Dev tooling for the founder-os plugin itself (test runners, CI). Not published; the plugin is distributed via .claude-plugin/plugin.json and the repo-root marketplace.json.",
  "scripts": {
    "test": "npm run test:core && npm run test:schema && npm run test:claude-code && npm run test:opencode && npm run test:hooks && npm run test:settings && npm run test:redos-guard && npm run test:audit-log && npm run test:repo-scans && npm run test:lint-harness && npm run test:lint-prd && npm run test:ci-drift && npm run check:version-sync",
    "test:core": "node tests/run-core-engine-tests.js",
    "test:audit-log": "tsx tests/run-audit-log-tests.js",
    "test:repo-scans": "node tests/run-repo-scan-tests.js",
    "test:lint-harness": "node tests/run-lint-harness-tests.js",
    "test:lint-prd": "node tests/run-lint-prd-tests.js",
    "test:schema": "node tests/run-schema-validation-tests.js",
    "test:claude-code": "node tests/run-policy-tests.js",
    "test:opencode": "tsx tests/run-opencode-policy-tests.ts",
    "test:hooks": "node tests/run-hook-tests.js",
    "test:settings": "tsx tests/run-settings-tests.js",
    "test:redos-guard": "node tests/run-redos-guard-tests.js",
    "test:ci-drift": "node tests/run-ci-drift-tests.js",
    "typecheck:opencode": "tsc --noEmit --target es2020 --module esnext --moduleResolution bundler adapters/opencode/plugin.ts",
    "validate:policy-schema": "node bin/validate-policy-schema.js",
    "check:version-sync": "node bin/check-version-sync.js",
    "check:js-syntax": "node bin/check-js-syntax.js",
    "scan:secrets": "node bin/scan-secrets.js",
    "audit:deps": "npm audit",
    "lint:harness": "node bin/lint-harness.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ajv": "^8.20.0",
    "tsx": "^4.22.0",
    "typescript": "^5.6.0"
  }
}
